// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  owner
  admin
  member
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  plan          Plan      @default(FREE)
  members     Member[]
  invitations Invitation[]
  evaluations Evaluation[]
  activityLogs ActivityLog[]


  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id @default(cuid()) 
  name        String
  slug        String
  logo        String?
  website     String?
  twitter String?
  linkedIn    String?
  instagram String?
  facebook String?
  createdAt   DateTime      @default(now())
  description    String?
  members     Member[]
  invitations Invitation[]
  jobs        Job[]
  categories  JobCategory[]
  pipelines   Pipeline[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @default(member)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           Role?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}


enum Type {
  FULLTIME
  PARTTIME
  FULLTIME_PARTTIME
  INTERNSHIP
  CONTRACT
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  CLOSED
}

enum LocationMode {
  ONSITE
  REMOTE
  HYBRID
}

enum SalaryInterval {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

model Job {
  id             String       @id @default(cuid())
  title          String
  type           Type         @default(FULLTIME)
  status         JobStatus    @default(DRAFT)
  locationMode   LocationMode @default(REMOTE)
  address        String?  
  country        String?
  city           String?
  description    String?
  showSalary     Boolean @default(false)
  salaryMin      Int?
  salaryMax      Int?
  currency       String?      @default("USD")
  salaryInterval SalaryInterval? 
  experienceLevel ExperienceLevel? @default(ENTRY)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applicants     Applicant[]
  categoryId     String?
  category       JobCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  questions      JobQuestion[]
  
  pipelineId     String
  pipeline       Pipeline    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("job")
}

model Pipeline {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages         Stage[]
  jobs           Job[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("pipeline")
}

model Stage {
  id             String       @id @default(cuid())
  name           String
  order          Int          @default(0)
  pipelineId     String
  pipeline       Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  applicants     Applicant[]
  evaluations    Evaluation[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([pipelineId])
  @@map("stage")
}

model Evaluation {
  id             String       @id @default(cuid())
  score          Int          // 1-5 scale
  feedback       String?
  interviewerId  String
  interviewer    User         @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  applicantId    String
  applicant      Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  stageId        String
  stage          Stage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([applicantId])
  @@index([stageId])
  @@map("evaluation")
}

model ActivityLog {
  id             String       @id @default(cuid())
  action         String       // e.g. "MOVED_STAGE", "ADDED_EVALUATION"
  metadata       Json?        // Stores old/new values
  actorId        String?
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  applicantId    String
  applicant      Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([applicantId])
  @@map("activity_log")
}

model Communication {
  id             String       @id @default(cuid())
  type           String       // EMAIL, NOTE, CALL
  content        String
  applicantId    String
  applicant      Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([applicantId])
  @@map("communication")
}

model JobQuestion {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  type        String   // SHORT_ANSWER, LONG_ANSWER, SELECT, CHECKBOX, etc.
  label       String
  placeholder String?
  required    Boolean  @default(false)
  options     String[] // For SELECT or MULTI_SELECT
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobId])
  @@map("job_question")
}

enum Status {
  SUBMITTED
  UNDERREVIEW
  INTERVIEW
  OFFER
  REJECTED
  HIRED
}

model Applicant {
  id             String       @id @default(cuid())
  name           String
  email          String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  status         Status       @default(SUBMITTED)
  resumeKey      String
  responses      Json         @default("{}")
  jobId          String
  job            Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  currentStageId String
  currentStage   Stage       @relation(fields: [currentStageId], references: [id], onDelete: Cascade)
  
  evaluations    Evaluation[]
  activityLogs   ActivityLog[]
  communications Communication[]

  @@index([jobId])
  @@index([currentStageId])
  @@map("applicant")
}

model JobCategory {
  id             String       @id @default(cuid())
  name           String
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobs           Job[]

  @@map("job_category")
}
